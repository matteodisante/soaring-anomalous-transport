# Ambienti / packaging
.venv/
venv/
env/
*.egg-info/
build/
dist/

# Cache Python / tooling
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Documentazione generata
site/

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp

# Dati grezzi: NON vanno mai nel repo (stanno sull'SSD esterno).
# Struttura: data/<disciplina>/ (paragliders/, hang_gliders/). Versioniamo SOLO i piccoli
# data/<disciplina>/seasons_index.csv; i catalog.csv (grandi, derivati) restano locali.
/data/*/catalog.csv
/data/*/track_scan.parquet
/data/*/igc/
/data/*/raw_xml/
/data/*/logs/
*.igc
# ...eccetto la piccola fixture di test del parser IGC, che va versionata.
!/tests/fixtures/*.igc

# Tesi (documento PUBBLICO): teniamo i .tex, thesis/generated/*.tex e thesis/main.pdf;
# ignoriamo solo gli ausiliari di LaTeX.
thesis/*.aux
thesis/*.bbl
thesis/*.bcf
thesis/*.blg
thesis/*.fdb_latexmk
thesis/*.fls
thesis/*.log
thesis/*.out
thesis/*.run.xml
thesis/*.synctex.gz
thesis/*.toc
thesis/*.lof
thesis/*.lot

# Figure di diagnostica: generate in locale da scripts/reporting/generate_preproc_figure.py
# (dipendono da data/catalog.csv, non versionato). NON committate; la tesi le include con
# \IfFileExists, quindi compila comunque anche quando la figura non c'e'.
thesis/generated/*.pdf

# Logbook (documento PUBBLICO, come la tesi): teniamo i .tex, la timeline generata
# e logbook.pdf; ignoriamo solo gli ausiliari di LaTeX.
logbook/*.aux
logbook/*.bbl
logbook/*.bcf
logbook/*.blg
logbook/*.fdb_latexmk
logbook/*.fls
logbook/*.log
logbook/*.out
logbook/*.run.xml
logbook/*.synctex.gz
logbook/*.toc
logbook/*.lof
logbook/*.lot
